# --- AI gateway -------------------------------------------------------------
# OpenRouter key — one key for every model family: https://openrouter.ai/keys
# With no key set, Argus runs in mock mode (canned data, fully offline).
OPENROUTER_API_KEY=

# Override the gateway if you use a different OpenAI-compatible endpoint.
# GATEWAY_BASE_URL=https://openrouter.ai/api/v1

# The swarm: three auditor models from three providers, plus a referee from a
# fourth family. Any OpenRouter slugs work.
ARGUS_AUDITORS=openai/gpt-4.1,google/gemini-2.5-pro,deepseek/deepseek-chat
ARGUS_REFEREE=qwen/qwen3-max

# Force mock mode even with a key set (demo-safety switch).
ARGUS_FORCE_MOCK=0

# --- Monad ------------------------------------------------------------------
# 10143 = Monad testnet (default) · 143 = Monad mainnet
ARGUS_CHAIN_ID=10143
# MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Etherscan V2 multichain key — used to fetch VERIFIED source for a pasted
# address. Optional: without it Argus still audits raw deployed bytecode.
ETHERSCAN_API_KEY=

# --- Registry (onchain attestations) -----------------------------------------
# Deploy with: npm run compile && ARGUS_SIGNER_KEY=0x… npm run deploy
ARGUS_REGISTRY_ADDRESS=
# Private key of the attester wallet (needs a little MON for gas).
ARGUS_SIGNER_KEY=

# Public URL of this deployment (used for OpenRouter attribution headers).
ARGUS_PUBLIC_URL=http://localhost:3000
