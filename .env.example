# --- AI gateway -------------------------------------------------------------
# One key for every model family. OpenRouter (https://openrouter.ai/keys) OR a
# direct provider like DeepSeek. With no key set, Auditora runs in mock mode.
GATEWAY_API_KEY=
# OPENROUTER_API_KEY also works and is used as a fallback.

# The gateway base URL. OpenRouter default shown; use a provider's URL for direct.
# GATEWAY_BASE_URL=https://openrouter.ai/api/v1
# GATEWAY_BASE_URL=https://api.deepseek.com

# --- The review board -------------------------------------------------------
# Auditora is a team of agents with DIFFERENT JOBS, not a vote of identical models.
#   AUDITORA_AUDITORS  = the Auditor(s): propose candidate findings (fast models are fine).
#   AUDITORA_CHALLENGER = the adversary: attacks each finding, upholds/disputes/rejects,
#                         and catches misses. Give this the STRONGEST reasoning model —
#                         judging a finding correctly is the hard job, and a weak
#                         Challenger causes false negatives (declaring a bug-free verdict
#                         on vulnerable code).
# The Challenger MUST differ from the Auditor, or it shares the Auditor's blind spots.
#
# OpenRouter (real multi-vendor):
#   AUDITORA_AUDITORS=openai/gpt-4.1,google/gemini-2.5-pro
#   AUDITORA_CHALLENGER=anthropic/claude-sonnet-5
# DeepSeek-only (fast proposes, reasoner challenges — a real asymmetry on one vendor):
AUDITORA_AUDITORS=deepseek-chat
AUDITORA_CHALLENGER=deepseek-reasoner
# AUDITORA_REFEREE is the legacy name the Challenger falls back to if CHALLENGER is unset.
AUDITORA_REFEREE=deepseek-reasoner

# Force mock mode even with a key set (demo-safety switch).
AUDITORA_FORCE_MOCK=0

# --- Monad ------------------------------------------------------------------
# 10143 = Monad testnet (default) · 143 = Monad mainnet
AUDITORA_CHAIN_ID=10143
# MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Etherscan V2 multichain key — used to fetch VERIFIED source for a pasted
# address. Optional: without it Auditora still audits raw deployed bytecode.
ETHERSCAN_API_KEY=

# --- Registry (onchain attestations) -----------------------------------------
# Deploy with: npm run compile && npm run deploy  (reads AUDITORA_SIGNER_KEY below)
AUDITORA_REGISTRY_ADDRESS=
# Private key of the attester wallet (needs a little MON for gas).
AUDITORA_SIGNER_KEY=

# Public URL of this deployment (used for OpenRouter attribution headers).
AUDITORA_PUBLIC_URL=http://localhost:3000
